<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kidslearning.mapper.EnglishMapper">
    <select id="selectByQuery" resultType="com.kidslearning.entity.English" parameterType="com.kidslearning.entity.query.EnglishQuery">
        SELECT * FROM english
        <where>
            <if test="keyword != null and keyword != ''">
                AND word LIKE CONCAT( #{keyword}, '%')
            </if>
        </where>
        ORDER BY id DESC
    </select>
</mapper>