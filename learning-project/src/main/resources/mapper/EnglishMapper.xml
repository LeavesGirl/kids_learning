<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kidslearning.mapper.EnglishMapper">
    <select id="selectByQuery" resultType="com.kidslearning.entity.English" parameterType="com.kidslearning.entity.query.EnglishQuery">
        SELECT * FROM english
        <where>
            <if test="query.word != null and query.word != ''">
                AND word LIKE CONCAT( #{query.word}, '%')
            </if>
            <if test="query.meaning != null and query.meaning != ''">
                AND meaning LIKE CONCAT( #{query.meaning}, '%')
            </if>
            <if test="query.type != null and query.type != ''">
                AND type = #{query.type}
            </if>
            <if test="query.learned != null">
                AND learned = #{query.learned}
            </if>
        </where>
        ORDER BY id ASC
    </select>
</mapper>
